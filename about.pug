doctype html
head
  // Required meta tags
  meta(charset='utf-8')
  meta(name='viewport' content='width=device-width, initial-scale=1')
  // Bootstrap CSS
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css' rel='stylesheet' integrity='sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC' crossorigin='anonymous')
  link(rel="stylesheet", href="style.css")
  title Hello, world!
body 
    header

    main.main-home
        include includes/navbar.pug
                        
        .internal-header.py-5.d-flex.flex-column.justify-content-center
            .container
                .row.text-primary 
                    .col-12.col-lg-5.mb-5 
                        .display-4.text-white The Team
               
        section.py-5
            .container 
                .row.text-center.justify-content-center 
                    .col-12.col-md-6
                        p.lead.mb-0 Lorem ipsum dolor sit amet consectetur adipisicing elit. Id, et. Provident esse hic quis culpa voluptate corrupti laborum quas tenetur!
        section.about-us.pb-5
            .container 
                .row   
                    .col-6.col-lg-3.text-center.mb-4 
                        img.img-fluid.mb-3.w-50(src="./images/sally.png", alt="")
                        p.fw-bold Amanda Fields
                        small Regional Manager
                        small.text-muted.d-block Atlanta, GA
                    .col-6.col-lg-3.text-center.mb-4 
                        img.img-fluid.mb-3.w-50(src="./images/don.png", alt="")
                        p.fw-bold Donald Juan
                        small District Manager
                        small.text-muted.d-block Atlanta, GA
                    .col-6.col-lg-3.text-center.mb-4 
                        img.img-fluid.mb-3.w-50(src="./images/jennifer.png", alt="")
                        p.fw-bold Jennifer Shohpez
                        small Talent Acquisition
                        small.text-muted.d-block Atlanta, GA
                    .col-6.col-lg-3.text-center.mb-4 
                        img.img-fluid.mb-3.w-50(src="./images/kareem.png", alt="")
                        p.fw-bold Kareem Jabar
                        small Talent Acquisition
                        small.text-muted.d-block Atlanta, GA
        
        include includes/blog.pug
                          
    footer.py-3
        small.d-block.text-center Copyright 2021 mindMatch.com

